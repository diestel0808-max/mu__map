{
  "version": 2,
  "rewrites": [
    { "source": "/api/kopis", "destination": "/api/kopis.js" },
    { "source": "/api/ocr",   "destination": "/api/ocr.js"   },
    { "source": "/api/db",    "destination": "/api/db.js"    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}
